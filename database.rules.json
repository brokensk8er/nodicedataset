{
  "rules": {
    "nodice": {
      "poll": {
        ".read": true,
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['question', 'options', 'active']) || newData.child('active').val() === false",
        "question": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 120"
        },
        "options": {
          ".validate": "newData.hasChildren(['0', '1'])",
          "$idx": {
            ".validate": "$idx.matches(/^[0-4]$/) && newData.isString() && newData.val().length > 0 && newData.val().length <= 80"
          }
        },
        "active":   { ".validate": "newData.isBoolean()" },
        "revealed": { ".validate": "newData.isBoolean()" },
        "ts":       { ".validate": "newData.isNumber()" }
      },
      "votes": {
        ".read": true,
        ".write": "auth != null",
        "$voterId": {
          ".write": true,
          ".validate": "newData.isString() && newData.val().matches(/^[0-4]$/) && !data.exists()"
        }
      }
    },
    "encounters": {
      "{encounterId}": {
        ".read": true,
        ".write": "auth != null",
        "dragonHP": { ".validate": "newData.isNumber()" },
        "dragonMaxHP": { ".validate": "newData.isNumber()" },
        "status": { ".validate": "newData.val() matches /^(active|defeated|waiting)$/" },
        "startedAt": { ".validate": "newData.isNumber()" },
        "activePlayers": {
          "{userId}": {
            ".write": "auth != null",
            "lastAttackTime": { ".validate": "newData.isNumber()" },
            "onCooldown": { ".validate": "newData.isBoolean()" },
            "cooldownUntil": { ".validate": "newData.isNumber()" }
          }
        },
        "recentAttacks": {
          "{attackId}": {
            ".write": "auth != null",
            "userId": { ".validate": "newData.isString()" },
            "rollResult": { ".validate": "newData.val() matches /^(go_time|no_time)$/" },
            "timestamp": { ".validate": "newData.isNumber()" || newData.val() === null" }
          }
        },
        "counterAttackLog": {
          "{counterId}": {
            ".write": "auth != null",
            "targetUserId": { ".validate": "newData.isString()" },
            "timestamp": { ".validate": "newData.isNumber()" || newData.val() === null" },
            "cooldownUntil": { ".validate": "newData.isNumber()" }
          }
        }
      }
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
